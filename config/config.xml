<?xml version="1.0" encoding="UTF-8"?>
<config>

  <!-- true = roda sem abrir janela | false = mostra o Edge na tela -->
  <headless>true</headless>

  <!-- 0 = processa tudo | N = processa apenas os primeiros N itens (teste) -->
  <limite>0</limite>

  <!-- Token do GitHub para enviar o log automaticamente quando a maquina
       NAO for um repositorio git (ex.: execucao do exe no cliente).
       Deixe VAZIO no repositorio (o GitHub revoga tokens commitados).
       O token real e injetado apenas na copia que vai dentro do .zip. -->
  <github_token></github_token>

</config>
